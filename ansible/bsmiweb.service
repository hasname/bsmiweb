[Unit]
Description=bsmiweb web server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/service/bsmiweb
EnvironmentFile=/home/service/bsmiweb/.env
ExecStart=/home/service/.local/share/mise/shims/node --import ./src/instrument-web.js src/index.js
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
