// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Registration {
  id           String        @id // e.g. "R45879"
  taxId        String        @map("tax_id") // 統編
  applicant    String // 申請人
  contactAddr  String        @map("contact_addr") @db.Text // 聯絡地址
  companyAddr  String        @map("company_addr") @db.Text // 公司地址
  phone        String // 電話
  note         String        @db.Text // 廠商資料備註
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  certificates Certificate[]

  @@map("registration")
}

model Certificate {
  id             String       @id // 證書編號, e.g. "CI450068790054"
  registrationId String       @map("registration_id")
  validDate      String       @map("valid_date") // 有效期間 (民國日期, e.g. "1130202")
  status         String // 證書狀態 (認可/期限到期失效/註銷)
  productName    String       @map("product_name") @db.Text // 產品中文名稱
  soldAs         String       @map("sold_as") @db.Text // 以他人名義銷售
  mainModel      String       @map("main_model") // 主型式
  seriesModels   String       @map("series_models") @db.Text // 系列型號 (newline-separated)
  issuer         String // 發證單位
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  registration   Registration @relation(fields: [registrationId], references: [id])

  @@index([registrationId])
  @@map("certificate")
}

model Authorization {
  id              String   @id // 授權證號, e.g. "CI311072080028"
  certificateId   String   @map("certificate_id") // 原始證書編號
  authorizerName  String   @map("authorizer_name") // 授權人名稱
  mainModel       String   @map("main_model") // 主型式
  authorizeeTaxId String   @map("authorizee_tax_id") // 被授權人統編
  authorizeeName  String   @map("authorizee_name") // 被授權人名稱
  authorizeeAddr  String   @map("authorizee_addr") @db.Text // 被授權人地址
  authorizeePhone String   @map("authorizee_phone") // 被授權人電話
  validDate       String   @map("valid_date") // 授權有效時間, e.g. "2005/07/18"
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([certificateId])
  @@index([authorizeeTaxId])
  @@map("authorization")
}
